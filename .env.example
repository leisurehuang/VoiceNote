# Voice Notes 配置。复制为 .env 后按需修改（绝大多数情况下用默认值即可）。

PORT=3000

# ---- whisper.cpp ----
# whisper-cli 是 keg-only，默认不在 PATH。默认值通过 `brew --prefix whisper-cpp` 自动解析。
# WHISPER_CLI=/opt/homebrew/opt/whisper-cpp/bin/whisper-cli
# 模型文件路径（brew 不带模型，需运行 `npm run setup` 下载）
# 默认 turbo（~1.5GB，质量接近 large、速度快、内存占用小）；要换 large-v3 改文件名即可
WHISPER_MODEL=/Users/lei/.voice-notes-models/ggml-large-v3-turbo.bin
WHISPER_THREADS=8
WHISPER_LANGUAGE=auto
# 解码预热提示，偏置中文输出
WHISPER_PROMPT=以下是普通话的句子。

# ---- 摘要 LLM（OpenAI 兼容；默认本地 Ollama，可改成任意云 API）----
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_API_KEY=ollama
